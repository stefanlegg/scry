{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "scry",
  "title": "Scry - Dev Servers",
  "description": "View and manage your running development servers",
  "icon": "extension-icon.png",
  "author": "stefanlegg",
  "categories": ["Developer Tools"],
  "license": "MIT",
  "commands": [
    {
      "name": "list-servers",
      "title": "List Dev Servers",
      "description": "View all running development servers",
      "mode": "view"
    },
    {
      "name": "open-server",
      "title": "Open Dev Server",
      "description": "Quickly open a dev server in browser",
      "mode": "view"
    },
    {
      "name": "kill-server",
      "title": "Kill Dev Server",
      "description": "Stop a running dev server",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.64.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.8",
    "@types/node": "20.10.4",
    "@types/react": "18.2.42",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
